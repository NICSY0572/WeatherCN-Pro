#!name = WeatherCN Pro
#!desc = WeatherCN Pro v1.2 iPhone Ready: stable Apple Weather enhancement for Loon with safe fallback to original Apple responses.
#!author = WeatherCN Pro
#!homepage = https://github.com/NICSY0572/WeatherCN-Pro
#!plugin-url = https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/WeatherCN.plugin
#!date = 2026-07-04

[General]
skip-proxy = *.qweather.com, api.open-meteo.com, air-quality-api.open-meteo.com, api.weather.gov, weather.cma.cn

[Rule]
DOMAIN-SUFFIX,weather-data.apple.com,DIRECT
DOMAIN-SUFFIX,weatherkit.apple.com,DIRECT
DOMAIN-SUFFIX,weather-map.apple.com,DIRECT
DOMAIN-SUFFIX,qweather.com,DIRECT
DOMAIN,api.open-meteo.com,DIRECT
DOMAIN,air-quality-api.open-meteo.com,DIRECT
DOMAIN,api.weather.gov,DIRECT
DOMAIN-SUFFIX,cma.cn,DIRECT

[Script]
http-request ^https:\/\/weather-data\.apple\.com\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, timeout=4, tag=WeatherCN Pro Data Request, argument="QWEATHER_KEY=&DEBUG=0"
http-response ^https:\/\/weather-data\.apple\.com\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, requires-body=true, timeout=4, tag=WeatherCN Pro Data Response, argument="QWEATHER_KEY=&DEBUG=0"
http-request ^https?:\/\/weatherkit\.apple\.com\/api\/v1\/availability\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, timeout=4, tag=WeatherCN Pro Availability Request, argument="QWEATHER_KEY=&DEBUG=0"
http-response ^https?:\/\/weatherkit\.apple\.com\/api\/v1\/availability\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, requires-body=true, timeout=4, tag=WeatherCN Pro Availability Response, argument="QWEATHER_KEY=&DEBUG=0"
http-request ^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, timeout=4, tag=WeatherCN Pro Weather Request, argument="QWEATHER_KEY=&DEBUG=0"
http-response ^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/.* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, requires-body=true, binary-body-mode=true, timeout=20, tag=WeatherCN Pro Weather Response, argument="QWEATHER_KEY=&DEBUG=0"
http-request ^https:\/\/weatherkit\.apple\.com\/(?!api\/v1\/availability\/|api\/v2\/weather\/).* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, timeout=4, tag=WeatherCN Pro Legacy Request, argument="QWEATHER_KEY=&DEBUG=0"
http-response ^https:\/\/weatherkit\.apple\.com\/(?!api\/v1\/availability\/|api\/v2\/weather\/).* script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/Scripts/weathercn.js, requires-body=true, timeout=4, tag=WeatherCN Pro Legacy Response, argument="QWEATHER_KEY=&DEBUG=0"

[MITM]
hostname = weather-data.apple.com, weatherkit.apple.com, weather-map.apple.com
