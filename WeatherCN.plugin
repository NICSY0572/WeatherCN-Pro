#!name=WeatherCN Pro
#!desc=中国版 iPhone 天气增强插件；v0.3.0 修正版：插件配置与 JS 脚本分离。
#!author=NICSY0572 & GPT
#!homepage=https://github.com/NICSY0572/WeatherCN-Pro
#!icon=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/icon.png

[MITM]
hostname = weatherkit.apple.com, weather-data.apple.com

[Script]
http-response ^https:\/\/weatherkit\.apple\.com\/api\/v1\/weather\/.+ script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/weathercn-pro.js, requires-body=true, timeout=20, tag=WeatherCN Pro
http-response ^https:\/\/weather-data\.apple\.com\/.+ script-path=https://raw.githubusercontent.com/NICSY0572/WeatherCN-Pro/main/weathercn-pro.js, requires-body=true, timeout=20, tag=WeatherCN Pro Data
